/* row count and duplicates */
SELECT
  COUNT(*) AS total_rows,
  COUNT(DISTINCT order_id) AS unique_orders,
  COUNT(*) - COUNT(DISTINCT order_id) AS duplicate_count
FROM ecommerce.olist_orders;

/*null check across every column */
SELECT
  COUNTIF(order_id IS NULL) AS null_order_id,
  COUNTIF(customer_id IS NULL) AS null_customer_id,
  COUNTIF(order_status IS NULL) AS null_status,
  COUNTIF(order_purchase_timestamp IS NULL) AS null_purchase_ts,
  COUNTIF(order_approved_at IS NULL) AS null_approved_ts,
  COUNTIF(order_delivered_carrier_date IS NULL) AS null_carrier_date,
  COUNTIF(order_delivered_customer_date IS NULL) AS null_delivered_date,
  COUNTIF(order_estimated_delivery_date IS NULL) AS null_estimated_date
FROM ecommerce.olist_orders;

/*order status values */

SELECT
  order_status,
  COUNT(*) AS total,
  ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 2) AS pct
FROM ecommerce.olist_orders
GROUP BY order_status
ORDER BY total DESC;

/*impossibe timestamps */

SELECT
  COUNTIF(order_delivered_customer_date < order_purchase_timestamp)
    AS delivered_before_purchase,
  COUNTIF(order_approved_at < order_purchase_timestamp)
    AS approved_before_purchase,
  COUNTIF(order_delivered_carrier_date < order_purchase_timestamp)
    AS shipped_before_purchase,
  COUNTIF(order_delivered_customer_date < order_delivered_carrier_date)
    AS delivered_before_shipped
FROM ecommerce.olist_orders;

/* delivered orders with missing delivery date */

SELECT
  COUNT(*) AS delivered_but_no_date
FROM ecommerce.olist_orders
WHERE order_status = 'delivered'
AND order_delivered_customer_date IS NULL;

/* duplicate order_ids */

SELECT
  order_id,
  COUNT(*) AS occurrences
FROM ecommerce.olist_orders
GROUP BY order_id
HAVING COUNT(*) > 1
ORDER BY occurrences DESC;

/* date range sanity check */

SELECT
  MIN(order_purchase_timestamp) AS earliest_order,
  MAX(order_purchase_timestamp) AS latest_order,
  DATE_DIFF(
    MAX(order_purchase_timestamp),
    MIN(order_purchase_timestamp),
    DAY
  ) AS days_of_data
FROM ecommerce.olist_orders;







